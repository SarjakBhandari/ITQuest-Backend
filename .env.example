PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/itquest
CLIENT_ORIGIN=http://localhost:3000
OTP_TTL_MINUTES=10
BCRYPT_SALT_ROUNDS=10
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Optional SMTP — when omitted, OTP is logged to the server console
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@itquest.local
SITE_NAME=IT Quest
